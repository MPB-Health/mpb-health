# ============================================================================
# Cutover env file — copy to `.env.cutover` and fill in the values.
# `.env.cutover` is git-ignored (matches `.env*.local` glob); never commit.
# ============================================================================
#
# What we already verified is on ARYX:
#   ✅ RESEND_API_KEY              (set, digest ef55e43e…)
#   ✅ RESEND_WEBHOOK_SECRET       (set, digest 5c522a11…)
#   ✅ SUPABASE_*                  (set by the platform)
#
# What's still missing on ARYX edge functions and is required for new
# Microsoft 365 / Gmail / Calendly / GoTo Connect connects to work:
#   ❌ MS_OAUTH_CLIENT_ID          (Azure AD app registration)
#   ❌ MS_OAUTH_CLIENT_SECRET
#   ❌ MS_OAUTH_REDIRECT_URI       → must be ARYX URL now
#   ❌ MS_WEBHOOK_SECRET           (Graph clientState shared secret)
#   ❌ GOOGLE_OAUTH_CLIENT_ID
#   ❌ GOOGLE_OAUTH_CLIENT_SECRET
#   ❌ GOOGLE_OAUTH_REDIRECT_URI   → must be ARYX URL now
#   ❌ GMAIL_PUBSUB_TOPIC          (e.g. projects/mpb-prod/topics/gmail-events)
#   ❌ GOTO_CONNECT_API_KEY
#   ❌ MAIL_TOKEN_ENCRYPTION_KEY   (32-byte hex/base64 — needed to encrypt
#                                    OAuth tokens before storing in DB)
#   ❌ CRM_CALENDLY_WEBHOOK_SIGNING_KEY  (created when subscription is made)
#
# All of these were set on legacy Supabase (`dtmnkzllidaiqyheguhl`) — we
# verified the digests there. Re-paste the values here and the helper
# script `scripts/cutover/sync-secrets-to-aryx.sh` will install them on
# ARYX in one shot.
#
# ============================================================================
# Provider API tokens — needed by `scripts/cutover/repoint-*.ts` to LIST
# and DELETE/RECREATE existing webhook subscriptions.
# ============================================================================

# --- Calendly ---------------------------------------------------------------
# Mint a personal access token at:
#   https://calendly.com/integrations/api_webhooks
# Org URI: GET https://api.calendly.com/users/me with the token, copy
#          the `current_organization` URI from the response.
CALENDLY_PERSONAL_ACCESS_TOKEN=
CALENDLY_ORGANIZATION_URI=
CALENDLY_USER_URI=                      # optional, only if user-scoped subs exist
CALENDLY_SIGNING_KEY=                   # optional, share key across new subs

# --- Microsoft Graph (M365 / Outlook) --------------------------------------
# Same Azure AD app registration that powers OAuth. Open
#   https://portal.azure.com → Azure AD → App registrations → <your CRM app>
# `MS_GRAPH_TENANT_ID`     = Directory (tenant) ID
# `MS_GRAPH_CLIENT_ID`     = Application (client) ID  (same as MS_OAUTH_CLIENT_ID)
# `MS_GRAPH_CLIENT_SECRET` = Certificates & secrets → existing or new client secret
# `MS_WEBHOOK_SECRET`      = same `clientState` secret as on legacy/ARYX function
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_WEBHOOK_SECRET=

# --- Gmail / Google Pub/Sub ------------------------------------------------
# Service account with `roles/pubsub.editor` on the project that hosts the
# `gmail-events` topic. Download the JSON key in GCP console → IAM → Service
# Accounts → Keys → Add key.
GOOGLE_PROJECT_ID=
GOOGLE_PUBSUB_TOPIC=                    # full path: projects/<id>/topics/<name>
GOOGLE_SERVICE_ACCOUNT_JSON=            # absolute path to .json OR inline JSON

# Optional — only needed if any users.watch needs OAuth refresh during cutover
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ============================================================================
# Watchdog (used by check-legacy-traffic.ts)
# ============================================================================

SUPABASE_ACCESS_TOKEN=                  # sbp_… personal access token
WATCHDOG_ALERT_TO=ops@mympb.com,vincent@mympb.com
WATCHDOG_ALERT_THRESHOLD=0
RESEND_API_KEY=re_bAP86XPT_AemQ882u9VXCjANhwS7do2gK
ARYX_SUPABASE_SERVICE_ROLE_KEY=
