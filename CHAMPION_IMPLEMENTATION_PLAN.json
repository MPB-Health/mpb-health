{
  "projectName": "Champion Advisor OS",
  "baselineAssessment": {
    "repoStructure": "monorepo",
    "existingApps": ["admin-portal", "advisor-portal", "crm", "website"],
    "existingPackages": [
      "@mpbhealth/admin-core",
      "@mpbhealth/advisor-core",
      "@mpbhealth/auth",
      "@mpbhealth/config",
      "@mpbhealth/crm-core",
      "@mpbhealth/database",
      "@mpbhealth/ui",
      "@mpbhealth/utils",
      "@mpbhealth/integrations",
      "@mpbhealth/services"
    ],
    "packageNamingDecision": {
      "recommendation": "keep @mpbhealth/* for now",
      "rationale": "Renaming packages mid-project creates risk. Champion can be a product under MPB ownership. Transition to @champion/* only if legally separating entities."
    }
  },
  "existingCapabilities": {
    "authentication": {
      "status": "complete",
      "hasPasswordReset": false,
      "hasMultiTenant": false,
      "location": "packages/auth"
    },
    "leadsAndCRM": {
      "status": "partial",
      "mainTable": "zoho_lead_submissions",
      "hasFields": [
        "pipeline_stage", "assigned_to", "priority", "lead_score",
        "tags", "last_contacted_at", "next_followup_at"
      ],
      "hasActivities": true,
      "hasTasks": true,
      "hasAIInsights": true,
      "hasContacts": true,
      "hasAccounts": true,
      "hasDeals": true,
      "missingForChampion": [
        "org_id on all tables",
        "engagement threads/messages",
        "sequences/automation",
        "compliance workflows"
      ]
    },
    "training": {
      "status": "complete",
      "tables": ["training_modules", "training_progress", "certifications"]
    },
    "meetings": {
      "status": "complete",
      "tables": ["advisor_meetings", "meeting_invitations", "meeting_attendees"],
      "hasJitsi": true
    },
    "content": {
      "status": "complete",
      "tables": ["sop_documents", "bulletins", "advisor_forms"]
    }
  },
  "gapAnalysis": {
    "critical": [
      {
        "feature": "Multi-tenant Organizations",
        "currentState": "Single tenant (MPB only)",
        "required": "org_id on all tables + RLS scoping",
        "effort": "high",
        "phase": 0
      },
      {
        "feature": "Engagement Inbox",
        "currentState": "None",
        "required": "threads, messages, templates, channel routing",
        "effort": "high",
        "phase": 2
      },
      {
        "feature": "Priority OS",
        "currentState": "Basic lead list with priority field",
        "required": "lanes, scoring rules, daily power list",
        "effort": "medium",
        "phase": 1
      },
      {
        "feature": "Sequences Engine",
        "currentState": "None",
        "required": "automated multi-step outreach",
        "effort": "high",
        "phase": 2
      },
      {
        "feature": "Compliance Workflows",
        "currentState": "None",
        "required": "approvals, locked templates, disclaimers, audit",
        "effort": "medium",
        "phase": 2
      }
    ],
    "important": [
      {
        "feature": "Password Reset",
        "currentState": "None",
        "required": "forgot password flow + email",
        "effort": "low",
        "phase": 0
      },
      {
        "feature": "Calendar Sync",
        "currentState": "calendar_events table exists but no OAuth",
        "required": "Google/Microsoft OAuth + sync",
        "effort": "medium",
        "phase": 3
      },
      {
        "feature": "AI Assistant",
        "currentState": "ai_lead_insights exists",
        "required": "memory ingestion, embeddings, draft generation",
        "effort": "high",
        "phase": 4
      },
      {
        "feature": "Billing/Subscriptions",
        "currentState": "None",
        "required": "Stripe integration, plan gating",
        "effort": "medium",
        "phase": 5
      }
    ],
    "nice_to_have": [
      {
        "feature": "Presentation Builder",
        "currentState": "None",
        "required": "slides, share links, analytics",
        "effort": "high",
        "phase": 6
      },
      {
        "feature": "Mobile App",
        "currentState": "None",
        "required": "React Native or PWA",
        "effort": "very high",
        "phase": 7
      }
    ]
  },
  "targetArchitecture": {
    "apps": {
      "advisor-portal": {
        "rebrandTo": "Champion Portal",
        "changes": [
          "Add org context",
          "Add inbox route",
          "Add contacts route",
          "Enhance dashboard with Priority OS",
          "Add AI assistant panel"
        ]
      },
      "admin-portal": {
        "status": "exists",
        "enhance": [
          "Org management",
          "Template management",
          "Compliance settings",
          "Sequence builder",
          "Billing management",
          "Analytics dashboard"
        ]
      }
    },
    "newPackages": [
      {
        "name": "@mpbhealth/champion-core",
        "purpose": "Champion-specific services (priority OS, sequences, compliance)",
        "services": [
          "PriorityService",
          "SequenceService",
          "ComplianceService",
          "EngagementService",
          "AIAssistantService"
        ]
      },
      {
        "name": "@mpbhealth/messaging",
        "purpose": "Multi-channel messaging (email, SMS, in-app)",
        "services": [
          "EmailProvider",
          "SMSProvider",
          "MessageRouter"
        ]
      }
    ]
  },
  "databaseSchema": {
    "phase0_foundation": {
      "newTables": [
        {
          "name": "organizations",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "name": "text NOT NULL",
            "slug": "text UNIQUE NOT NULL",
            "brand_config": "jsonb DEFAULT '{}'",
            "settings": "jsonb DEFAULT '{}'",
            "subscription_tier": "text DEFAULT 'free'",
            "subscription_status": "text DEFAULT 'active'",
            "created_at": "timestamptz DEFAULT now()",
            "updated_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "org_memberships",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "user_id": "uuid REFERENCES auth.users(id) ON DELETE CASCADE",
            "role": "text NOT NULL CHECK (role IN ('owner', 'admin', 'manager', 'advisor'))",
            "status": "text DEFAULT 'active' CHECK (status IN ('active', 'invited', 'suspended'))",
            "created_at": "timestamptz DEFAULT now()",
            "updated_at": "timestamptz DEFAULT now()"
          },
          "constraints": ["UNIQUE(org_id, user_id)"]
        },
        {
          "name": "org_invites",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "email": "text NOT NULL",
            "role": "text NOT NULL",
            "token": "text UNIQUE NOT NULL",
            "invited_by": "uuid REFERENCES auth.users(id)",
            "expires_at": "timestamptz NOT NULL",
            "accepted_at": "timestamptz",
            "created_at": "timestamptz DEFAULT now()"
          }
        }
      ],
      "alterTables": [
        {
          "table": "zoho_lead_submissions",
          "add": ["org_id uuid REFERENCES organizations(id)"],
          "note": "Backfill with default org for existing data"
        },
        {
          "table": "advisor_profiles",
          "add": ["org_id uuid REFERENCES organizations(id)"]
        },
        {
          "table": "crm_contacts",
          "note": "Already has org_id"
        },
        {
          "table": "crm_accounts",
          "note": "Already has org_id"
        }
      ],
      "rlsFunctions": [
        {
          "name": "get_user_org_ids",
          "returns": "uuid[]",
          "body": "SELECT array_agg(org_id) FROM org_memberships WHERE user_id = auth.uid() AND status = 'active'"
        },
        {
          "name": "user_has_org_access",
          "params": "check_org_id uuid",
          "returns": "boolean",
          "body": "EXISTS (SELECT 1 FROM org_memberships WHERE org_id = check_org_id AND user_id = auth.uid() AND status = 'active')"
        },
        {
          "name": "user_has_org_role",
          "params": "check_org_id uuid, allowed_roles text[]",
          "returns": "boolean",
          "body": "EXISTS (SELECT 1 FROM org_memberships WHERE org_id = check_org_id AND user_id = auth.uid() AND status = 'active' AND role = ANY(allowed_roles))"
        }
      ]
    },
    "phase1_priorityOS": {
      "newTables": [
        {
          "name": "priority_lanes",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "name": "text NOT NULL",
            "description": "text",
            "color": "text DEFAULT '#6B7280'",
            "order_index": "integer DEFAULT 0",
            "auto_rules": "jsonb DEFAULT '[]'",
            "is_active": "boolean DEFAULT true",
            "created_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "priority_items",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "lane_id": "uuid REFERENCES priority_lanes(id) ON DELETE CASCADE",
            "contact_id": "uuid",
            "lead_id": "uuid",
            "reason": "text",
            "score": "integer DEFAULT 0",
            "rank": "integer",
            "owner_user_id": "uuid REFERENCES auth.users(id)",
            "snoozed_until": "timestamptz",
            "completed_at": "timestamptz",
            "created_at": "timestamptz DEFAULT now()",
            "updated_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "scoring_rules",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "name": "text NOT NULL",
            "description": "text",
            "trigger_type": "text NOT NULL",
            "conditions": "jsonb NOT NULL",
            "score_delta": "integer NOT NULL",
            "lane_assignment": "uuid REFERENCES priority_lanes(id)",
            "is_active": "boolean DEFAULT true",
            "created_at": "timestamptz DEFAULT now()"
          }
        }
      ]
    },
    "phase2_engagement": {
      "newTables": [
        {
          "name": "threads",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "contact_id": "uuid",
            "lead_id": "uuid",
            "channel": "text NOT NULL CHECK (channel IN ('email', 'sms', 'call', 'in_app'))",
            "subject": "text",
            "status": "text DEFAULT 'open' CHECK (status IN ('open', 'closed', 'snoozed'))",
            "last_message_at": "timestamptz",
            "assigned_to": "uuid REFERENCES auth.users(id)",
            "created_at": "timestamptz DEFAULT now()",
            "updated_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "messages",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "thread_id": "uuid REFERENCES threads(id) ON DELETE CASCADE",
            "direction": "text NOT NULL CHECK (direction IN ('inbound', 'outbound'))",
            "channel": "text NOT NULL",
            "from_address": "text",
            "to_address": "text",
            "subject": "text",
            "body": "text NOT NULL",
            "body_html": "text",
            "metadata": "jsonb DEFAULT '{}'",
            "status": "text DEFAULT 'sent'",
            "sent_at": "timestamptz",
            "delivered_at": "timestamptz",
            "read_at": "timestamptz",
            "created_by": "uuid REFERENCES auth.users(id)",
            "created_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "message_templates",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "name": "text NOT NULL",
            "description": "text",
            "channel": "text NOT NULL",
            "subject": "text",
            "body": "text NOT NULL",
            "variables": "text[] DEFAULT '{}'",
            "is_locked": "boolean DEFAULT false",
            "requires_approval": "boolean DEFAULT false",
            "compliance_tags": "text[] DEFAULT '{}'",
            "created_by": "uuid REFERENCES auth.users(id)",
            "created_at": "timestamptz DEFAULT now()",
            "updated_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "sequences",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "name": "text NOT NULL",
            "description": "text",
            "trigger_type": "text NOT NULL",
            "trigger_conditions": "jsonb DEFAULT '{}'",
            "is_active": "boolean DEFAULT true",
            "created_by": "uuid REFERENCES auth.users(id)",
            "created_at": "timestamptz DEFAULT now()",
            "updated_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "sequence_steps",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "sequence_id": "uuid REFERENCES sequences(id) ON DELETE CASCADE",
            "step_index": "integer NOT NULL",
            "delay_hours": "integer DEFAULT 0",
            "delay_type": "text DEFAULT 'hours' CHECK (delay_type IN ('hours', 'days', 'business_days'))",
            "channel": "text NOT NULL",
            "template_id": "uuid REFERENCES message_templates(id)",
            "action_type": "text DEFAULT 'send_message'",
            "conditions": "jsonb DEFAULT '{}'",
            "created_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "sequence_enrollments",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "sequence_id": "uuid REFERENCES sequences(id) ON DELETE CASCADE",
            "contact_id": "uuid",
            "lead_id": "uuid",
            "current_step": "integer DEFAULT 0",
            "status": "text DEFAULT 'active' CHECK (status IN ('active', 'paused', 'completed', 'cancelled', 'replied'))",
            "next_run_at": "timestamptz",
            "started_at": "timestamptz DEFAULT now()",
            "completed_at": "timestamptz",
            "cancelled_at": "timestamptz",
            "cancelled_reason": "text",
            "created_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "jobs",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id)",
            "job_type": "text NOT NULL",
            "payload": "jsonb NOT NULL",
            "priority": "integer DEFAULT 0",
            "run_at": "timestamptz NOT NULL",
            "status": "text DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'completed', 'failed', 'cancelled'))",
            "attempts": "integer DEFAULT 0",
            "max_attempts": "integer DEFAULT 3",
            "last_error": "text",
            "completed_at": "timestamptz",
            "created_at": "timestamptz DEFAULT now()"
          }
        }
      ]
    },
    "phase2_compliance": {
      "newTables": [
        {
          "name": "compliance_rules",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "name": "text NOT NULL",
            "description": "text",
            "rule_type": "text NOT NULL",
            "conditions": "jsonb NOT NULL",
            "action": "jsonb NOT NULL",
            "is_active": "boolean DEFAULT true",
            "created_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "approvals",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "object_type": "text NOT NULL",
            "object_id": "uuid NOT NULL",
            "status": "text DEFAULT 'pending' CHECK (status IN ('pending', 'approved', 'rejected', 'cancelled'))",
            "requested_by": "uuid REFERENCES auth.users(id)",
            "assigned_to": "uuid REFERENCES auth.users(id)",
            "decided_by": "uuid REFERENCES auth.users(id)",
            "decided_at": "timestamptz",
            "decision_notes": "text",
            "created_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "audit_logs",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id)",
            "actor_user_id": "uuid REFERENCES auth.users(id)",
            "action": "text NOT NULL",
            "object_type": "text NOT NULL",
            "object_id": "uuid",
            "old_values": "jsonb",
            "new_values": "jsonb",
            "ip_address": "inet",
            "user_agent": "text",
            "created_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "disclaimer_templates",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "name": "text NOT NULL",
            "content": "text NOT NULL",
            "channel": "text NOT NULL",
            "is_required": "boolean DEFAULT true",
            "position": "text DEFAULT 'footer' CHECK (position IN ('header', 'footer', 'both'))",
            "is_active": "boolean DEFAULT true",
            "created_at": "timestamptz DEFAULT now()"
          }
        }
      ]
    },
    "phase3_calendar": {
      "newTables": [
        {
          "name": "calendar_connections",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "user_id": "uuid REFERENCES auth.users(id) ON DELETE CASCADE",
            "provider": "text NOT NULL CHECK (provider IN ('google', 'microsoft', 'apple'))",
            "account_email": "text",
            "access_token_encrypted": "text",
            "refresh_token_encrypted": "text",
            "token_expires_at": "timestamptz",
            "sync_enabled": "boolean DEFAULT true",
            "last_synced_at": "timestamptz",
            "status": "text DEFAULT 'active'",
            "created_at": "timestamptz DEFAULT now()",
            "updated_at": "timestamptz DEFAULT now()"
          },
          "constraints": ["UNIQUE(user_id, provider)"]
        },
        {
          "name": "tasks",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "title": "text NOT NULL",
            "description": "text",
            "task_type": "text DEFAULT 'general'",
            "contact_id": "uuid",
            "lead_id": "uuid",
            "deal_id": "uuid",
            "due_at": "timestamptz",
            "reminder_at": "timestamptz",
            "priority": "text DEFAULT 'medium'",
            "status": "text DEFAULT 'pending' CHECK (status IN ('pending', 'in_progress', 'completed', 'cancelled'))",
            "completed_at": "timestamptz",
            "assigned_to": "uuid REFERENCES auth.users(id)",
            "created_by": "uuid REFERENCES auth.users(id)",
            "created_at": "timestamptz DEFAULT now()",
            "updated_at": "timestamptz DEFAULT now()"
          }
        }
      ],
      "note": "calendar_events table already exists in your schema"
    },
    "phase4_ai": {
      "newTables": [
        {
          "name": "documents",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "title": "text NOT NULL",
            "source_type": "text NOT NULL",
            "source_url": "text",
            "file_path": "text",
            "content_text": "text",
            "content_hash": "text",
            "status": "text DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'completed', 'failed'))",
            "chunk_count": "integer DEFAULT 0",
            "created_by": "uuid REFERENCES auth.users(id)",
            "created_at": "timestamptz DEFAULT now()",
            "updated_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "memory_chunks",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "document_id": "uuid REFERENCES documents(id) ON DELETE CASCADE",
            "chunk_index": "integer NOT NULL",
            "chunk_text": "text NOT NULL",
            "embedding": "vector(1536)",
            "metadata": "jsonb DEFAULT '{}'",
            "created_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "assistant_profiles",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "user_id": "uuid REFERENCES auth.users(id) ON DELETE CASCADE",
            "voice_style": "jsonb DEFAULT '{}'",
            "writing_samples": "text[] DEFAULT '{}'",
            "allowed_actions": "text[] DEFAULT '{}'",
            "required_disclaimers": "text[] DEFAULT '{}'",
            "auto_send_enabled": "boolean DEFAULT false",
            "created_at": "timestamptz DEFAULT now()",
            "updated_at": "timestamptz DEFAULT now()"
          },
          "constraints": ["UNIQUE(org_id, user_id)"]
        },
        {
          "name": "ai_drafts",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "contact_id": "uuid",
            "lead_id": "uuid",
            "channel": "text NOT NULL",
            "subject": "text",
            "body": "text NOT NULL",
            "context_used": "jsonb DEFAULT '{}'",
            "status": "text DEFAULT 'draft' CHECK (status IN ('draft', 'approved', 'sent', 'rejected'))",
            "approved_by": "uuid REFERENCES auth.users(id)",
            "approved_at": "timestamptz",
            "created_by": "uuid REFERENCES auth.users(id)",
            "created_at": "timestamptz DEFAULT now()"
          }
        }
      ],
      "extensions": ["vector"],
      "note": "Requires pgvector extension for embeddings"
    },
    "phase5_billing": {
      "newTables": [
        {
          "name": "subscription_plans",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "name": "text NOT NULL",
            "slug": "text UNIQUE NOT NULL",
            "description": "text",
            "price_monthly": "integer NOT NULL",
            "price_yearly": "integer",
            "features": "jsonb NOT NULL",
            "limits": "jsonb NOT NULL",
            "stripe_price_id_monthly": "text",
            "stripe_price_id_yearly": "text",
            "is_active": "boolean DEFAULT true",
            "sort_order": "integer DEFAULT 0",
            "created_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "subscriptions",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "plan_id": "uuid REFERENCES subscription_plans(id)",
            "stripe_subscription_id": "text UNIQUE",
            "stripe_customer_id": "text",
            "status": "text DEFAULT 'active'",
            "billing_cycle": "text DEFAULT 'monthly'",
            "current_period_start": "timestamptz",
            "current_period_end": "timestamptz",
            "cancel_at_period_end": "boolean DEFAULT false",
            "cancelled_at": "timestamptz",
            "created_at": "timestamptz DEFAULT now()",
            "updated_at": "timestamptz DEFAULT now()"
          }
        },
        {
          "name": "usage_records",
          "fields": {
            "id": "uuid PRIMARY KEY DEFAULT gen_random_uuid()",
            "org_id": "uuid REFERENCES organizations(id) ON DELETE CASCADE",
            "metric": "text NOT NULL",
            "quantity": "integer NOT NULL",
            "period_start": "timestamptz NOT NULL",
