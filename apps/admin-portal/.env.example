# Copy to .env (or merge with your existing file) and fill from Supabase: Settings > API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# External membership / sales analytics Supabase (Unified Analytics → Membership & Sales tab).
# Use the anon key only. Never add a service-role key with a VITE_ prefix.
VITE_MEMBERSHIP_ANALYTICS_SUPABASE_URL=
VITE_MEMBERSHIP_ANALYTICS_SUPABASE_ANON_KEY=

# Rich text for ticket replies (Tiptap). Requires ITSTS migration (content_format) + ticket-proxy deploy.
# Use "true" to enable; omit or "false" for legacy textarea + plain text.
VITE_RICH_TICKET_EDITOR=true
