VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: absolute origin where public web forms are served (e.g. https://crm.example.com).
# If unset, share/copy links use the current browser origin (works when forms open on the same host).
# VITE_PUBLIC_WEB_FORM_BASE_URL=https://crm.example.com

# LinkedIn OAuth is handled by Supabase Edge Functions (not Vite). Set these in the Supabase project
# (Dashboard → Edge Functions → Secrets) after deploying `social-linkedin-auth-url` and
# `social-linkedin-oauth-callback`:
#   LINKEDIN_OAUTH_CLIENT_ID
#   LINKEDIN_OAUTH_CLIENT_SECRET
#   LINKEDIN_OAUTH_REDIRECT_URI  → must equal https://<project-ref>.supabase.co/functions/v1/social-linkedin-oauth-callback
#   MAIL_TOKEN_ENCRYPTION_KEY      → same secret as mail OAuth; used with public.encrypt_token
# Optional:
#   LINKEDIN_OAUTH_STATE_SECRET    → defaults to MAIL_TOKEN_ENCRYPTION_KEY
#   LINKEDIN_OAUTH_SCOPES          → defaults to "openid profile email"
#   SOCIAL_LINKEDIN_FRONTEND_REDIRECT → where users land after OAuth; default http://localhost:5173/social-media
