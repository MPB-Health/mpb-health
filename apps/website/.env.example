# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# REMOVED: Service role key must NEVER be in client-side code (VITE_ prefix exposes it in the browser bundle)
# Use Supabase Edge Functions for any operations requiring elevated privileges

# Resend Email Service
VITE_RESEND_API_KEY=your_resend_api_key_here

# Mailchimp Configuration
# REMOVED: Mailchimp API key is now handled server-side via Supabase Edge Functions
# Configure MAILCHIMP_API_KEY in your Supabase Edge Function environment variables
VITE_MAILCHIMP_AUDIENCE_ID=your_mailchimp_audience_id_here
VITE_MAILCHIMP_SERVER_PREFIX=your_mailchimp_server_prefix_here

# Google API / Search Console Configuration
VITE_GOOGLE_CLIENT_ID=your_client_id
VITE_GOOGLE_CLIENT_SECRET=your_client_secret
VITE_GOOGLE_REDIRECT_URI=your_redirect_uri

# Analytics Configuration
# Google Analytics 4
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Social Media Pixels
VITE_FB_PIXEL_ID=your_facebook_pixel_id_here
VITE_LINKEDIN_INSIGHT_TAG=your_linkedin_insight_tag_here
VITE_TWITTER_PIXEL_ID=your_twitter_pixel_id_here
VITE_PINTEREST_TAG_ID=your_pinterest_tag_id_here
VITE_TIKTOK_PIXEL_ID=your_tiktok_pixel_id_here
VITE_REDDIT_PIXEL_ID=your_reddit_pixel_id_here
VITE_SNAPCHAT_PIXEL_ID=your_snapchat_pixel_id_here

# Behavioral Analytics
VITE_CLARITY_PROJECT_ID=your_microsoft_clarity_project_id_here
VITE_HOTJAR_SITE_ID=your_hotjar_site_id_here
VITE_HOTJAR_VERSION=6

# Open Enrollment Configuration
VITE_OPEN_ENROLLMENT_START=2025-11-01
VITE_OPEN_ENROLLMENT_END=2026-01-01
VITE_OPEN_ENROLLMENT_ENABLED=true

# Zoho CRM Integration
# Note: These credentials are now stored securely in Supabase Edge Function environment variables
# The client-side code no longer needs direct access to Zoho credentials
# Configure these in your Supabase project dashboard under Edge Functions > Secrets:
# - ZOHO_CLIENT_ID
# - ZOHO_CLIENT_SECRET
# - ZOHO_REFRESH_TOKEN
# - ZOHO_API_DOMAIN (optional, defaults to https://www.zohoapis.com)

# CAPTCHA (Cloudflare Turnstile)
# TURNSTILE_SECRET_KEY must be set in Supabase Edge Function secrets (Dashboard > Edge Functions > Secrets)
VITE_CAPTCHA_ENABLED=false
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Cognito Forms Configuration
VITE_COGNITO_FORMS_API_KEY=your_cognito_forms_api_key_here
VITE_COGNITO_QUOTE_FORM_ID=your_cognito_form_id_here

# n8n Webhook Configuration
VITE_N8N_LEAD_WEBHOOK_URL=your_n8n_webhook_url_here
