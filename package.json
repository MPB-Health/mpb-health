{
  "name": "mpbhealth-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm exec turbo run dev",
    "dev:website": "pnpm --filter @mpbhealth/website dev",
    "dev:crm": "pnpm --filter @mpbhealth/crm dev",
    "dev:advisor": "pnpm --filter @mpbhealth/advisor-portal dev",
    "dev:admin": "pnpm --filter @mpbhealth/admin-portal dev",
    "dev:staff-hub": "pnpm --filter @mpbhealth/staff-hub dev",
    "dev:concierge": "pnpm --filter @mpbhealth/concierge-portal dev",
    "build": "pnpm exec turbo run build",
    "build:website": "pnpm exec turbo run build --filter=@mpbhealth/website",
    "build:crm": "pnpm exec turbo run build --filter=@mpbhealth/crm",
    "build:advisor": "pnpm exec turbo run build --filter=@mpbhealth/advisor-portal",
    "build:admin": "pnpm exec turbo run build --filter=@mpbhealth/admin-portal",
    "build:staff-hub": "pnpm exec turbo run build --filter=@mpbhealth/staff-hub",
    "build:concierge": "pnpm exec turbo run build --filter=@mpbhealth/concierge-portal",
    "lint": "pnpm exec turbo run lint",
    "typecheck": "pnpm exec turbo run typecheck",
    "test": "pnpm exec turbo run test",
    "test:crm": "pnpm --filter @mpbhealth/crm test",
    "test:unit:crm-core": "pnpm --filter @mpbhealth/crm-core test",
    "test:e2e": "playwright test",
    "test:e2e:crm": "playwright test --project=crm",
    "test:e2e:ui": "playwright test --ui",
    "verify:crm-bundle": "pnpm --filter @mpbhealth/crm build:verify",
    "clean": "pnpm exec turbo run clean && rm -rf node_modules",
    "db:generate": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > packages/database/src/types/database.ts",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "diagrams:png": "node scripts/export-diagram-pngs.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@playwright/test": "^1.49.0",
    "@resvg/resvg-js": "^2.6.2",
    "prettier": "^3.8.1",
    "turbo": "^2.8.11"
  },
  "engines": {
    "node": "20.x"
  },
  "pnpm": {
    "overrides": {
      "dompurify": ">=3.3.2"
    }
  }
}
