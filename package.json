{
  "name": "mpbhealth-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "dev:website": "turbo run dev --filter=website",
    "dev:crm": "turbo run dev --filter=@mpbhealth/crm",
    "dev:advisor": "turbo run dev --filter=@mpbhealth/advisor-portal",
    "dev:admin": "turbo run dev --filter=admin-portal",
    "build": "turbo run build",
    "build:website": "turbo run build --filter=website",
    "build:crm": "turbo run build --filter=crm",
    "build:advisor": "turbo run build --filter=advisor-portal",
    "build:admin": "turbo run build --filter=admin-portal",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:crm": "pnpm --filter @mpbhealth/crm test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > packages/database/src/types/database.ts",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "diagrams:png": "node scripts/export-diagram-pngs.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@playwright/test": "^1.49.0",
    "@resvg/resvg-js": "^2.6.2",
    "prettier": "^3.8.1",
    "turbo": "^2.8.11"
  },
  "engines": {
    "node": "20.x"
  },
  "pnpm": {
    "overrides": {
      "dompurify": ">=3.3.2"
    }
  }
}
