{
  "name": "@mpbhealth/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external react --external @mpbhealth/utils",
    "dev": "tsup src/index.ts --format esm --dts --external react --external @mpbhealth/utils --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "catalog:",
    "@supabase/supabase-js": "catalog:"
  },
  "dependencies": {
    "@mpbhealth/database": "workspace:*",
    "@mpbhealth/utils": "workspace:*"
  },
  "devDependencies": {
    "@mpbhealth/typescript-config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
