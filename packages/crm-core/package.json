{
  "name": "@mpbhealth/crm-core",
  "version": "0.1.0",
  "description": "CRM business logic and services for MPB Health",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./leads": {
      "import": "./dist/leads/index.js",
      "types": "./dist/leads/index.d.ts"
    },
    "./activities": {
      "import": "./dist/activities/index.js",
      "types": "./dist/activities/index.d.ts"
    },
    "./tasks": {
      "import": "./dist/tasks/index.js",
      "types": "./dist/tasks/index.d.ts"
    },
    "./pipeline": {
      "import": "./dist/pipeline/index.js",
      "types": "./dist/pipeline/index.d.ts"
    },
    "./zoho": {
      "import": "./dist/zoho/index.js",
      "types": "./dist/zoho/index.d.ts"
    },
    "./notifications": {
      "import": "./dist/notifications/index.js",
      "types": "./dist/notifications/index.d.ts"
    },
    "./priority": {
      "import": "./dist/priority/index.js",
      "types": "./dist/priority/index.d.ts"
    },
    "./calendar": {
      "import": "./dist/calendar/index.js",
      "types": "./dist/calendar/index.d.ts"
    },
    "./insights": {
      "import": "./dist/insights/index.js",
      "types": "./dist/insights/index.d.ts"
    },
    "./templates": {
      "import": "./dist/templates/index.js",
      "types": "./dist/templates/index.d.ts"
    },
    "./email": {
      "import": "./dist/email/index.js",
      "types": "./dist/email/index.d.ts"
    },
    "./automation": {
      "import": "./dist/automation/index.js",
      "types": "./dist/automation/index.d.ts"
    },
    "./reporting": {
      "import": "./dist/reporting/index.js",
      "types": "./dist/reporting/index.d.ts"
    },
    "./scoring": {
      "import": "./dist/scoring/index.js",
      "types": "./dist/scoring/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/leads/index.ts src/activities/index.ts src/tasks/index.ts src/pipeline/index.ts src/zoho/index.ts src/notifications/index.ts src/priority/index.ts src/calendar/index.ts src/insights/index.ts src/templates/index.ts src/email/index.ts src/automation/index.ts src/reporting/index.ts src/scoring/index.ts --format esm --dts",
    "dev": "tsup src/index.ts src/leads/index.ts src/activities/index.ts src/tasks/index.ts src/pipeline/index.ts src/zoho/index.ts src/notifications/index.ts src/priority/index.ts src/calendar/index.ts src/insights/index.ts src/templates/index.ts src/email/index.ts src/automation/index.ts src/reporting/index.ts src/scoring/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mpbhealth/database": "workspace:*"
  },
  "devDependencies": {
    "@mpbhealth/typescript-config": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.x"
  }
}
