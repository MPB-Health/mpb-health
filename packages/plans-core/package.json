{
  "name": "@mpbhealth/plans-core",
  "version": "0.1.0",
  "description": "Shared plan management, pricing, and rate engine for MPB Health",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mpbhealth/database": "workspace:*"
  },
  "devDependencies": {
    "@mpbhealth/typescript-config": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.x"
  }
}
