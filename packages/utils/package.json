{
  "name": "@mpbhealth/utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./validation": {
      "import": "./dist/validation/index.js",
      "types": "./dist/validation/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/validation/index.ts --format esm --dts",
    "dev": "tsup src/index.ts src/validation/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dompurify": "^3.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@mpbhealth/typescript-config": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
